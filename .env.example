# ComplyKar environment
# Server port (default 8103)
PORT=8103

# WhatsApp reminder provider. "mock" (default) sends nothing — it writes
# deterministic messages to the in-app Outbox with FNV-hashed message ids.
# Setting "live" (with the credentials below) is where a real WhatsApp
# Cloud API integration would plug into the notify.Sender interface.
WHATSAPP_PROVIDER=mock
# WHATSAPP_API_TOKEN=your-meta-cloud-api-token
# WHATSAPP_PHONE_ID=your-sender-phone-number-id
